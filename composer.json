{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "art35rennes/laravel-daisy-kit-demo",
    "type": "project",
    "description": "Documentation and demo application for Art35rennes Daisy Kit.",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "art35rennes/laravel-daisy-kit": "dev-main",
        "laravel/framework": "^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.25",
        "pestphp/pest": "^4.1",
        "pestphp/pest-plugin-browser": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../laravel-daisy-kit",
            "options": {
                "symlink": true,
                "versions": {
                    "art35rennes/laravel-daisy-kit": "dev-main"
                }
            }
        }
    ],
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan key:generate --ansi",
            "@php artisan migrate --graceful --ansi"
        ],
        "test": "@php artisan test --exclude-group=tooling tests/Unit tests/Feature",
        "test:tooling": "pest --group=tooling tests/Unit tests/Feature",
        "test:browser": "pest tests/Browser",
        "lint": "pint --parallel",
        "inventory:update": "@php artisan inventory:update"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
